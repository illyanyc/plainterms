# OpenAI
OPENAI_API_KEY=sk-proj-your-openai-api-key

# Serper.dev (reputation search)
SERPER_API_KEY=your-serper-api-key

# Stripe (payments)
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
STRIPE_PRO_PRICE_ID=price_your-stripe-price-id

# JWT (auth between extension and backend)
JWT_SECRET=your-jwt-secret-at-least-32-chars-long

# CORS (comma-separated origins)
CORS_ORIGINS=chrome-extension://your-extension-id,http://localhost:3000
